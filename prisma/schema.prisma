generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUsers {
  id        String   @id @default(nanoid())
  name      String
  email     String   @unique
  password  String
  // role      ADMIN_ROLE @default(ADMIN)
  isActive  Boolean  @default(true)
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// enum ADMIN_ROLE {
//   ADMIN
//   MANAGER
//   STAFF
// }

enum STATUS {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum CUSTOMER_STATUS {
  PURCHASED
  INTERESTED
  BOOKED
  INPROGRESS
  LOST
  PAID_HALF
}

enum PROPERTY_STATUS {
  AVAILABLE
  SOLD
  RESERVED
  IN_PROGRESS
}

enum PROPERTY_TYPE {
  BUY
  RENT
  SELL
  PLOTS
}

enum PROPERTY_CATEGORY {
  BUILDING
  APARTMENT
  PLOT
}

enum TARGET_TYPE {
  PROJECT
  PROPERTY
  BOTH
}

enum PropertyUsageType {
  RESIDENTIAL
  COMMERCIAL
}

model Agent {
  id         String     @id @default(uuid())
  name       String
  email      String     @unique
  phone      String
  bio        String?
  properties Property[]
  addedAt    DateTime   @default(now())
}

model Address {
  id           String     @id @default(uuid())
  label        String
  city         String
  street       String
  state        String
  zipCode      Int
  longitude    Float?
  latitude     Float?
  nearbyPlaces Json[]
  gmaps        String?
  properties   Property[]
}

model Leads {
  id     String  @id @default(nanoid())
  name   String
  email  String
  phone  String
  budget String?
  status STATUS  @default(NEW)
  note   String?

  // Relations with property
  propertyId   String?
  property     Property?     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  updatedAt    DateTime      @updatedAt
  createdAt    DateTime      @default(now())
  fingerprints Fingerprints?

  followups LeadFollowup[]
  meetings  LeadMeeting[]
  tasks     LeadTask[]

  @@index([email])
  @@index([phone])
}

model LeadFollowup {
  id     String @id @default(nanoid())
  leadId String
  lead   Leads  @relation(fields: [leadId], references: [id], onDelete: Cascade)

  message   String
  createdAt DateTime @default(now())
}

enum MEETING_STATUS {
  SCHEDULED
  EMAIL_SENT
  COMPLETED
  CANCELLED
}

model LeadMeeting {
  id     String @id @default(nanoid())
  leadId String
  lead   Leads  @relation(fields: [leadId], references: [id], onDelete: Cascade)

  title String

  // 🔥 NEW CORE FIELDS (IMPORTANT)
  location    String // site visit location / office / property address
  scheduledAt DateTime // date + time of meeting

  status MEETING_STATUS @default(SCHEDULED)

  emailSent Boolean @default(false)

  createdAt DateTime @default(now())
}

enum TASK_STATUS {
  PENDING
  COMPLETED
}

enum TASK_PRIORITY {
  LOW
  MEDIUM
  HIGH
}

model LeadTask {
  id     String @id @default(nanoid())
  leadId String
  lead   Leads  @relation(fields: [leadId], references: [id], onDelete: Cascade)

  title       String
  dueDate     DateTime?
  status      TASK_STATUS   @default(PENDING)
  completedAt DateTime?
  tags        String[]
  priority    TASK_PRIORITY @default(MEDIUM)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Property {
  id              String            @id @default(uuid())
  title           String
  description     String
  images          String[]
  documents       Json?
  youtubeLink     String?
  amenities       String[]
  features        String[]
  isHidden        Boolean           @default(false)
  category        PROPERTY_TYPE
  status          PROPERTY_STATUS   @default(AVAILABLE)
  propertyType    PROPERTY_CATEGORY @default(APARTMENT)
  pngImage        String?
  price           Int
  Area            Int
  featured        Boolean           @default(false)
  usageType       PropertyUsageType @default(RESIDENTIAL)
  NearByLocations Json[]

  // optional I d k what to keep what to not
  BedRooms   Int?        @default(0)
  Bathrooms  Int?        @default(0)
  parking    Int?        @default(0)
  furnishing String?     @default("Unfurnished")
  HoaFees    Int?        @default(0)
  yearBuilt  Int?
  targetType TARGET_TYPE @default(PROPERTY)

  // Relations
  Leads      Leads[]
  agent      Agent[]
  addressId  String
  address    Address    @relation(fields: [addressId], references: [id])
  customerId String?
  customer   Customers? @relation(fields: [customerId], references: [id])

  updateAt  DateTime @updatedAt
  createdAt DateTime @default(now())
  proposalmails PropertyProposalMail[]
}

model PropertyProposalMail {
  id            String   @id @default(cuid())
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id])
  recipientName  String
  recipientEmail String
  subject       String
  body          String
  attachmentUrl String?
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  createdById   String?
  status        MAIL_STATUS @default(DRAFT)
}

enum MAIL_STATUS {
  DRAFT
  SENT
  FAILED
}
model Customers {
  id    String  @id @default(uuid())
  name  String
  image String?
  email String  @unique
  phone String

  dealAmount    Int?
  paymentMethod String?
  closingDate   DateTime?
  note          String?

  nationality String?         @default("Qatari")
  status      CUSTOMER_STATUS @default(BOOKED)
  properties  Property[]
  createdAt   DateTime        @default(now())
}

model Fingerprints {
  id          String @id @default(nanoid())
  fingerprint String
  username    String
  leadId      String @unique
  Lead        Leads  @relation(fields: [leadId], references: [id], onDelete: Cascade)
}
