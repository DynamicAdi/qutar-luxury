generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum STATUS {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum CUSTOMER_STATUS {
  PURCHASED
  INTERESTED
  BOOKED
  INPROGRESS
  LOST
  PAID_HALF
}

enum PROPERTY_STATUS {
  AVAILABLE
  SOLD
  RESERVED
  IN_PROGRESS
}

enum PROPERTY_TYPE {
  BUY
  RENT
  SELL
  PLOTS
  RESIDENTIAL
  COMMERCIAL
}

enum PROPERTY_CATEGORY {
  BUILDING
  APARTMENT
  PLOT
}

enum TARGET_TYPE{
  PROJECT
  PROPERTY
  BOTH
}

model Agent {
  id         String     @id @default(uuid())
  name       String
  email      String     @unique
  phone      String
  bio        String?
  properties Property[]
  addedAt    DateTime   @default(now())
}

model Address {
  id           String     @id @default(uuid())
  label        String
  city         String
  street       String
  state        String
  zipCode      Int
  longitude    Float?
  latitude     Float?
  nearbyPlaces Json[]
  gmaps        String?
  properties   Property[]
}

model Leads {
  id     String  @id @default(nanoid())
  name   String
  email  String  @unique
  phone  String
  budget String?
  status STATUS  @default(NEW)
  note   String?

  // Relations with property
  propertyId   String?
  property     Property?     @relation(fields: [propertyId], references: [id])
  updatedAt    DateTime      @updatedAt
  createdAt    DateTime      @default(now())
  fingerprints Fingerprints?
}

model Property {
  id           String            @id @default(uuid())
  title        String
  description  String
  images       String[]
  youtubeLink  String?
  amenities    String[]
  features     String[]
  isHidden     Boolean           @default(false)
  category     PROPERTY_TYPE
  status       PROPERTY_STATUS   @default(AVAILABLE)
  propertyType PROPERTY_CATEGORY @default(APARTMENT)
  pngImage     String?
  price        Int
  Area         Int
  featured Boolean @default(false)
  NearByLocations Json[]
  // optional I d k what to keep what to not
  BedRooms        Int?    @default(0)
  Bathrooms       Int?    @default(0)
  parking         Int?    @default(0)
  furnishing      String? @default("Unfurnished")
  HoaFees         Int?    @default(0)
  yearBuilt       Int?
  targetType  TARGET_TYPE @default(PROPERTY)
  // Relations
  Leads      Leads[]
  agent      Agent[]
  addressId  String
  address    Address    @relation(fields: [addressId], references: [id])
  customerId String?
  customer   Customers? @relation(fields: [customerId], references: [id])

  updateAt  DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Customers {
  id            String          @id @default(uuid())
  name          String
  image         String?
  email         String          @unique
  phone         String

  dealAmount    Int?
  paymentMethod String?
  closingDate   DateTime?
  note          String?
  
  nationality   String?         @default("Qatari")
  status        CUSTOMER_STATUS @default(BOOKED)
  properties    Property[]
  createdAt     DateTime        @default(now())
}

model Fingerprints {
  id          String @id @default(nanoid())
  fingerprint String
  username    String
  leadId      String @unique
  Lead        Leads  @relation(fields: [leadId], references: [id])
}
